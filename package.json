{
  "name": "cours-interactifs",
  "version": "1.0.0",
  "description": "Application web interactive pour cours et QCM",
  "main": "index.html",
  "scripts": {
    "start": "http-server -p 8000 -o index.html",

    "frontend": "http-server -p 8000 -o index.html",

    "backend": "cd backend && npm start",

    "dev": "npm run config:local && concurrently \"npm run frontend\" \"npm run backend\"",

    "config:local": "shx cp storage/config.local.json storage/config.json",

    "config:supabase": "shx cp storage/config.supabase.json storage/config.json",

    "test": "node -e \"fetch('http://localhost:3000/api/health').then(r=>r.json()).then(console.log).catch(console.error)\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "http-server": "^14.1.1",
    "shx": "^0.4.0"
  },
  "keywords": [
    "education",
    "qcm",
    "interactive",
    "excel"
  ],
  "author": "Cours Interactifs",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  }
}
